import subprocess
import sys

def install_packages():
    packages = ['pandas', 'matplotlib', 'seaborn', 'requests']
    for package in packages:
        try:
            __import__(package)
        except ImportError:
            print(f"正在安装 {package}...")
            subprocess.check_call([sys.executable, "-m", "pip", "install", package])

install_packages()
